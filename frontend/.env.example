# Mapbox GL JS access token (get one free at https://console.mapbox.com/)
# The app works without a token using OpenStreetMap tiles as fallback,
# but Mapbox provides better terrain/satellite imagery and styling.
REACT_APP_MAPBOX_TOKEN=pk.your_mapbox_token_here

# Backend API URL (not used in GitHub Pages mode — data is embedded at build time)
REACT_APP_API_URL=http://localhost:3000/api
