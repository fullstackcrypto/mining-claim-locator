# Frontend environment variables
# Copy this file to .env and fill in the values.
# NEVER commit the .env file – it is listed in .gitignore.

# Google Maps JavaScript API key (required for the interactive map)
# Create a key at https://console.cloud.google.com/apis/credentials
# Restrict the key to your GitHub Pages domain for security.
REACT_APP_GOOGLE_MAPS_API_KEY=

# Backend API base URL (optional)
# Leave blank to use sample data embedded in the frontend.
# Example: https://mining-claim-locator-api.onrender.com/api
REACT_APP_API_URL=
